NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecom_saas_db
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_64_chars_minimum_here_please
JWT_REFRESH_SECRET=change_me_refresh_secret_64_chars_minimum_here_please
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=*

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
